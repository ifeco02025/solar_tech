<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>SolarTech Energy</title>

  <meta name="description"
    content="Premium solar installation company providing solar panels, batteries, inverters, and renewable energy solutions." />

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

  <!-- HEADER -->

  <header class="header">

    <div class="container nav-container">

      <h1 class="logo">SolarTech</h1>

      <nav id="navbar">
        <ul class="nav-links">
          <li><a href="#home">Home</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#services">Services</a></li>
          <li><a href="#gallery">Gallery</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>

      <div class="nav-actions">

        <button id="darkModeToggle" class="dark-btn">
          <i class="fa-solid fa-moon"></i>
        </button>

        <button id="menuToggle" class="menu-btn">
          <i class="fa-solid fa-bars"></i>
        </button>

      </div>

    </div>

  </header>

  <!-- HERO -->

  <section id="home" class="swiper mySwiper hero-section">

    <div class="swiper-wrapper">

      <div class="swiper-slide hero-slide"
        style="background-image:url('https://images.unsplash.com/photo-1509391366360-2e959784a276?q=80&w=1974&auto=format&fit=crop')">

        <div class="overlay"></div>

        <div class="hero-content">
          <h1>Reliable Solar Energy Solutions</h1>

          <p>
            Premium solar panels, batteries and inverter systems.
          </p>

          <a href="#gallery" class="hero-btn">
            Explore Products
          </a>
        </div>

      </div>

      <div class="swiper-slide hero-slide"
        style="background-image:url('https://images.unsplash.com/photo-1497440001374-f26997328c1b?q=80&w=1974&auto=format&fit=crop')">

        <div class="overlay"></div>

      </div>

      <div class="swiper-slide hero-slide"
        style="background-image:url('https://images.unsplash.com/photo-1466611653911-95081537e5b7?q=80&w=2070&auto=format&fit=crop')">

        <div class="overlay"></div>

      </div>

      <div class="swiper-slide hero-slide" style="background-image:url('/images/solar 2.jpg')">

        <div class="overlay"></div>

      </div>
      <div class="swiper-slide hero-slide" style="background-image:url('/images/solar 3.jpg')">

        <div class="overlay"></div>

      </div>
            <div class="swiper-slide hero-slide" style="background-image:url('/images/solar 4.jpg')">

        <div class="overlay"></div>

      </div>
            <div class="swiper-slide hero-slide" style="background-image:url('/images/solar 7.jpg')">

        <div class="overlay"></div>
    </div>

    <div class="swiper-pagination"></div>

  </section>

  <!-- ABOUT -->

  <section id="about" class="about-section">

    <div class="container about-grid">

      <div class="about-image">
        <img src="https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?q=80&w=1974&auto=format&fit=crop"
          alt="Solar Installation">
      </div>

      <div class="about-content">

        <span class="section-tag">ABOUT SOLARTECH</span>

        <h2>
          Powering Homes & Businesses With Reliable Solar Energy
        </h2>

        <p class="about-text">
          SolarTech Energy was founded with a vision to make clean,
          affordable, and dependable electricity accessible to homes,
          offices, and businesses across Nigeria. Over the years,
          we have successfully delivered premium solar installations,
          inverter systems, batteries, and renewable energy solutions
          tailored to our customers' energy needs.
        </p>

        <div class="about-boxes">

          <div class="about-card">
            <i class="fa-solid fa-bullseye"></i>
            <h3>Our Mission</h3>

            <p>
              To provide efficient and sustainable solar energy
              solutions that reduce electricity costs and improve
              everyday living.
            </p>
          </div>

          <div class="about-card">
            <i class="fa-solid fa-eye"></i>
            <h3>Our Vision</h3>

            <p>
              To become one of the most trusted renewable energy
              companies in Africa through innovation, quality,
              and customer satisfaction.
            </p>
          </div>

        </div>

        <div class="trust-box">

          <h3>Why Customers Trust Us</h3>

          <ul>
            <li>✔ Premium quality solar products</li>
            <li>✔ Professional installation team</li>
            <li>✔ Reliable after-sales support</li>
            <li>✔ Affordable and scalable energy solutions</li>
            <li>✔ Trusted by homes and businesses</li>
          </ul>

        </div>

      </div>

    </div>

  </section>

  <!-- SERVICES -->

  <section id="services" class="services-section">

    <div class="container">

      <div class="section-title">

        <span class="section-tag">OUR SERVICES</span>

        <h2>
          Smart Solar Solutions For Every Need
        </h2>

        <p>
          We provide premium renewable energy services designed
          for homes, offices, and commercial buildings.
        </p>

      </div>

      <div class="services-grid">

        <div class="service-card">

          <div class="service-icon">
            <i class="fa-solid fa-solar-panel"></i>
          </div>

          <h3>Solar Installation</h3>

          <p>
            Professional solar installation services for homes,
            offices, and commercial properties.
          </p>

        </div>

        <div class="service-card">

          <div class="service-icon">
            <i class="fa-solid fa-battery-full"></i>
          </div>

          <h3>Solar Batteries</h3>

          <p>
            Premium lithium and tubular batteries designed
            for long backup performance.
          </p>

        </div>

        <div class="service-card">

          <div class="service-icon">
            <i class="fa-solid fa-bolt"></i>
          </div>

          <h3>Inverters</h3>

          <p>
            High-performance inverter systems with smart
            energy management technology.
          </p>

        </div>

        <div class="service-card">

          <div class="service-icon">
            <i class="fa-solid fa-screwdriver-wrench"></i>
          </div>

          <h3>Maintenance</h3>

          <p>
            Reliable repair, maintenance, and upgrade services
            for all solar systems.
          </p>

        </div>

        <div class="service-card">

          <div class="service-icon">
            <i class="fa-solid fa-clipboard-check"></i>
          </div>

          <h3>Consultation</h3>

          <p>
            Expert energy planning, inspection, and consultation
            tailored to your power needs.
          </p>

        </div>

        <div class="service-card">

          <div class="service-icon">
            <i class="fa-solid fa-solar-panel"></i>
          </div>

          <h3>Energy Upgrade</h3>

          <p>
            Upgrade existing solar systems for improved
            efficiency and better performance.
          </p>

        </div>

      </div>

    </div>

  </section>

  <!-- GALLERY -->
  <!-- GALLERY -->
  <!-- GALLERY -->
  <!-- GALLERY -->
  <section id="gallery" class="gallery-section">

    <div class="container">

      <div class="section-title">
        <span class="section-tag">OUR PRODUCTS</span>

        <h2>Latest Solar Products</h2>

        <p>
          Explore our latest solar products.
        </p>
      </div>

      <div class="gallery-grid">

        <% products.forEach(product=> { %>

          <div class="gallery-card">

            <img src="<%= product.images[0] %>" alt="">

            <div class="gallery-overlay">

              <span class="gallery-badge">
                <%= product.category %>
              </span>

              <h3>
                <%= product.title %>
              </h3>

              <ul>
                <li>₦ <%= product.price %>
                </li>
                <p id="description" placeholder="Description" required>
                  <%= product.description%>
                </p>


                <% product.specifications.forEach(spec=> { %>
                  <li>✔ <%= spec %>
                  </li>
                  <% }) %>

              </ul>

            </div>

          </div>

          <% }) %>

      </div>

    </div>

  </section>
  <!-- GALLERY -->



  <!-- CONTACT -->

  <!-- CONTACT SECTION -->

  <section id="contact" class="contact-section">

    <div class="contact-container">

      <span class="section-tag">
        CONTACT US
      </span>

      <h2>
        Let’s Power Your Home With Solar Energy
      </h2>

      <p>
        Need solar installation, batteries, inverters,
        or professional consultation? Our team is ready
        to help you switch to reliable renewable energy.
      </p>

      <div class="contact-boxes">

        <div class="contact-card">

          <i class="fa-solid fa-phone-volume"></i>

          <h3>Call Us</h3>

          <p>+234 801 234 5678</p>

        </div>

        <div class="contact-card">

          <i class="fa-solid fa-location-dot"></i>

          <h3>Our Location</h3>

          <p>Abuja, Nigeria</p>

        </div>

        <div class="contact-card">

          <i class="fa-solid fa-envelope"></i>

          <h3>Email Address</h3>

          <p>support@solartech.com</p>

        </div>

      </div>

      <a href="https://wa.me/2348012345678" target="_blank" class="contact-btn">

        <i class="fab fa-whatsapp"></i>

        Chat On WhatsApp

      </a>

    </div>

  </section>
  <!-- FOOTER -->

  <footer class="footer">

    <div class="container footer-container">

      <!-- FOOTER TOP -->

      <div class="footer-grid">

        <!-- COMPANY INFO -->

        <div class="footer-about">

          <h2>SolarTech Energy</h2>

          <p>
            We provide reliable solar installation services,
            premium batteries, inverters, and renewable energy
            solutions for homes and businesses.
          </p>

          <div class="footer-socials">

            <a href="#">
              <i class="fab fa-facebook-f"></i>
            </a>

            <a href="#">
              <i class="fab fa-instagram"></i>
            </a>

            <a href="#">
              <i class="fab fa-whatsapp"></i>
            </a>

            <a href="#">
              <i class="fab fa-linkedin-in"></i>
            </a>

          </div>

        </div>

        <!-- QUICK LINKS -->

        <div class="footer-links">

          <h3>Quick Links</h3>

          <ul>

            <li>
              <a href="#home">Home</a>
            </li>

            <li>
              <a href="#about">About Us</a>
            </li>

            <li>
              <a href="#services">Services</a>
            </li>

            <li>
              <a href="#gallery">Gallery</a>
            </li>

            <li>
              <a href="#contact">Contact</a>
            </li>

          </ul>

        </div>

        <!-- SERVICES -->

        <div class="footer-links">

          <h3>Our Services</h3>

          <ul>

            <li>
              <a href="#">Solar Installation</a>
            </li>

            <li>
              <a href="#">Solar Batteries</a>
            </li>

            <li>
              <a href="#">Hybrid Inverters</a>
            </li>

            <li>
              <a href="#">Maintenance</a>
            </li>

            <li>
              <a href="#">Consultation</a>
            </li>

          </ul>

        </div>

        <!-- CONTACT INFO -->

        <div class="footer-contact">

          <h3>Contact Info</h3>

          <p>
            <i class="fa-solid fa-phone"></i>
            +234 801 234 5678
          </p>

          <p>
            <i class="fa-solid fa-envelope"></i>
            support@solartech.com
          </p>

          <p>
            <i class="fa-solid fa-location-dot"></i>
            Abuja, Nigeria
          </p>

        </div>

      </div>

      <!-- FOOTER BOTTOM -->

      <div class="footer-bottom">

        <p>
          © 2026 SolarTech Energy. All Rights Reserved.
        </p>

        <!-- <p>
        Designed for reliable renewable energy solutions.
      </p> -->

      </div>

    </div>

  </footer>

  <!-- FLOATING WHATSAPP -->

  <a href="https://wa.me/2348012345678" target="_blank" class="whatsapp-float">

    <i class="fab fa-whatsapp"></i>

  </a>

  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

  <script src="/js/app.js"></script>

</body>

</html>